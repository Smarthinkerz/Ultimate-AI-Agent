# Ultimate AI Agent System Configuration
# Copy to .env and fill in your values. NEVER commit .env

# LLM Provider (primary). Supports any LangChain chat model.
# For Grok/xAI: Use OPENAI_API_KEY with base_url=https://api.x.ai/v1 or dedicated if available
LLM_PROVIDER=openai  # openai | anthropic | groq | xai | local
LLM_MODEL=gpt-4o  # or grok-2-1212, claude-3-5-sonnet-20240620, etc.
LLM_TEMPERATURE=0.2  # Lower for reasoning tasks; raise slightly for creative synthesis
LLM_MAX_TOKENS=8192
OPENAI_API_KEY=sk-...  # Or equivalent for your provider
# OPENAI_BASE_URL=https://api.openai.com/v1  # Override for Grok, Together, Fireworks, etc.

# Embeddings (for vector memory)
EMBEDDING_PROVIDER=openai  # openai | huggingface | local
EMBEDDING_MODEL=text-embedding-3-large
# HUGGINGFACE_API_KEY=... 

# Memory Backends
VECTOR_DB_PATH=./data/chroma  # Persistent Chroma dir
STRUCTURED_DB_PATH=./data/agent_memory.sqlite
EPISODIC_LOG_PATH=./data/episodic_logs.jsonl
CHECKPOINT_DB_PATH=./data/checkpoints.sqlite  # For LangGraph persistence

# User Calibration (deep persistent)
USER_ID=tahir_senyurt
USER_NAME="Tahir ŞENYURT"
CALIBRATION_SEED_PATH=./config/user_calibration_seed.json  # Bootstrap facts from memory.md

# Governance & Safety
HUMAN_APPROVAL_REQUIRED=true  # For high-impact: self-mod, external comms, financial
MAX_REFINEMENT_PASSES=4
MAX_TOOL_COST_USD=5.00  # Per task budget before throttling
ENABLE_SELF_IMPROVEMENT=true
LOG_LEVEL=INFO

# Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ultimate-ai-agent

# Deployment
ENVIRONMENT=development  # development | staging | production
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]  # For frontend integration e.g. Brainpower UI

# Optional: Japan/GCC specific or cultural
DEFAULT_CULTURAL_CONTEXT=oman_gcc  # or japan, turkey, general
SHARIA_REVIEW_ENABLED=true  # Contextual, not legal advice

# Tool Allow/Deny (JSON string or separate file)
ALLOWED_TOOLS=["pdf_analyzer","financial_modeler","curriculum_designer","visual_prompt_generator","japan_market_simulator","decision_graph_modeler","sharia_ethics_reviewer","code_generator","web_search_governed"]
DENIED_TOOLS=["unrestricted_shell","arbitrary_code_exec"]